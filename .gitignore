# ---------------------------------------------------------------------------
# Dependencias (no versionar; restaurar con npm install / pip install)
# ---------------------------------------------------------------------------
node_modules/

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
# Caché de bytecode (*.pyc suelto en subcarpetas: **/*.pyc)
__pycache__/
**/__pycache__/
*.pyc
**/*.pyc
*.pyo
**/*.pyo
*.pyd
**/*.pyd
*.py[cod]
*.class
.Python
venv/
.venv/
env/
.env/
*.egg-info/
.eggs/
dist/
build/

# ---------------------------------------------------------------------------
# Variables de entorno y credenciales
# ---------------------------------------------------------------------------
.env
.env.local
.env.*.local

# ---------------------------------------------------------------------------
# Caché y archivos generados en runtime
# ---------------------------------------------------------------------------
# GIFs generados por GEE (limpieza automática cada 60 min)
static/gifs/

# Mapas de riesgo renderizados desde GeoTIFFs (servidor o GEE)
static/flood_maps/

# ---------------------------------------------------------------------------
# TypeScript build output (src/ts/ → static/)
# Se regeneran con: npm run build:ts
# ---------------------------------------------------------------------------
/static/*.js
/static/*.js.map
/static/*.d.ts
/static/*.d.ts.map
static/**/*.js
static/**/*.d.ts
static/**/*.js.map
static/**/*.d.ts.map

# ---------------------------------------------------------------------------
# Documentación/scripts auxiliares (no parte del core)
# ---------------------------------------------------------------------------
misc/

# ---------------------------------------------------------------------------
# SDD / Agent artifacts (locales, no versionar)
# ---------------------------------------------------------------------------
.atl/

# ---------------------------------------------------------------------------
# IDE y editores
# ---------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~

# ---------------------------------------------------------------------------
# Sistema operativo
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ---------------------------------------------------------------------------
# Logs y temporales
# ---------------------------------------------------------------------------
*.log
*.tmp
*.temp
.cache/

# ---------------------------------------------------------------------------
# Testing y cobertura
# ---------------------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
.tox/

# Este archivo debe estar en UTF-8. Si Cursor lo guarda en UTF-16, Git no aplicará las reglas.
